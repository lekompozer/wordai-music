# Copy this file to .env.local and fill in the values
# Never commit .env.local

# Firebase (same project as wordai.pro)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Backend API
NEXT_PUBLIC_API_URL=https://ai.wordai.pro

# Desktop OAuth (Google Cloud Console → Desktop app client)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Tauri update signing key (generate with: npx tauri signer generate -w .env.local)
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
