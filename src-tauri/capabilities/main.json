{
    "$schema": "../gen/schemas/windows-schema.json",
    "identifier": "main",
    "description": "WordAI Music capabilities",
    "windows": [
        "main"
    ],
    "urls": [
        "http://localhost:3001/**"
    ],
    "permissions": [
        "core:default",
        "core:event:default",
        "core:event:allow-listen",
        "core:event:allow-unlisten",
        "core:event:allow-emit",
        "core:window:allow-start-dragging",
        "shell:allow-open",
        "updater:default",
        "dialog:allow-open"
    ]
}